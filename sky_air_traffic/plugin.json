{
  "tesserae_compat": "1.x",
  "name": "Sky, Air Traffic",
  "version": "0.1.2",
  "kind": "widget",
  "description": "Flights currently overhead at your location via OpenSky Network (free, no key). Shows count + the nearest N flights with callsign / origin country / altitude / speed.",
  "icon": "ph-airplane-tilt",
  "supports": { "sizes": ["sm", "md", "lg"] },
  "cell_options": [
    { "name": "latitude",  "type": "number", "label": "Latitude",                 "default": "" },
    { "name": "longitude", "type": "number", "label": "Longitude",                "default": "" },
    { "name": "radius_km", "type": "number", "label": "Search radius (km)",       "default": 60 },
    { "name": "max_results","type": "number","label": "Max flights to list",      "default": 8 }
  ],
  "render": { "dither": "none", "needs_network": true }
}
